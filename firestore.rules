rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. users 컬렉션 규칙: 자기 자신의 데이터만 읽고 쓰기 가능
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. families 컬렉션 규칙: 본인이 소속된 가족 그룹만 읽기, 소유자만 수정/삭제
    match /families/{familyId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
        && familyId == ('fam_' + request.auth.uid)
        && request.resource.data.ownerId == request.auth.uid;

      // 3. 가족 그룹 내부의 logs(혈당 등 기록) 서브컬렉션 규칙
      match /logs/{logId} {
        // members면 열람 및 새 기록 작성 가능, 수정/삭제는 소유자만
        allow read, create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
        allow update, delete: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/families/$(familyId)).data.ownerId;
      }
    }
  }
}
